    "svelte": "^5.37.0",
    "svelte-check": "^4.3.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "image-size": "^2.0.2",
